---
interface Props {
  text: string;
  link: string;
  active?: boolean;
}

const { text, link, active = false } = Astro.props;
---

<a
  href={link}
  class:list={['sidebar-link', { active }]}
  aria-current={active ? 'page' : undefined}
>
  {text}
</a>

<style>
  .sidebar-link {
    display: block;
    padding: 0.3rem 1rem 0.3rem 1.5rem;
    font-size: 0.85rem;
    color: var(--text-color);
    text-decoration: none;
    line-height: 1.6;
    transition: color 0.15s ease;
    border-left: 3px solid transparent;
  }

  .sidebar-link:hover {
    color: var(--accent-color);
    text-decoration: none;
  }

  .sidebar-link.active {
    color: var(--accent-color);
    border-left-color: var(--accent-color);
    background-color: rgba(17, 168, 205, 0.05);
    font-weight: 500;
  }
</style>
