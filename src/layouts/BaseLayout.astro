---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import BackToTop from '../components/BackToTop.astro';
import { SITE_CONFIG } from '../utils/site-config';

interface Props {
  title?: string;
  description?: string;
  pageClass?: string;
  ogType?: string;
}

const {
  title = SITE_CONFIG.title,
  description = SITE_CONFIG.description,
  pageClass = '',
  ogType = 'website',
} = Astro.props;

const fullTitle = title === SITE_CONFIG.title ? title : `${title} | ${SITE_CONFIG.title}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="keywords" content="前端博客,个人技术博客,前端,前端开发,前端框架,web前端,前端面试题,技术文档,学习,面试,JavaScript,js,ES6,TypeScript,vue,python,css3,html5,Node,git,github,markdown" />
  <meta name="theme-color" content="#0969A5" />
  <meta name="referrer" content="no-referrer-when-downgrade" />
  <link rel="icon" href="/img/a.jpg" />
  <link rel="stylesheet" href="https://at.alicdn.com/t/font_3077305_pt8umhrn4k9.css" />
  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content={ogType} />
  <title>{fullTitle}</title>
</head>
<body class={pageClass}>
  <ReadingProgress />
  <header>
    <Navbar />
  </header>
  <main>
    <slot />
  </main>
  <Footer />
  <BackToTop />
  <script src="../scripts/love-me.js"></script>
  <script src="../scripts/time-greeting.js"></script>
  <script src="../scripts/typing-animation.js"></script>
</body>
</html>
