---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import BackToTop from '../components/BackToTop.astro';
import { SITE_CONFIG } from '../utils/site-config';

interface Props {
  title?: string;
  description?: string;
  pageClass?: string;
  ogType?: string;
}

const {
  title = SITE_CONFIG.title,
  description = SITE_CONFIG.description,
  pageClass = '',
  ogType = 'website',
} = Astro.props;

const fullTitle = title === SITE_CONFIG.title ? title : `${title} | ${SITE_CONFIG.title}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="keywords" content="前端博客,个人技术博客,前端,前端开发,前端框架,web前端,前端面试题,技术文档,学习,面试,JavaScript,js,ES6,TypeScript,vue,python,css3,html5,Node,git,github,markdown" />
  <meta name="theme-color" content="#0969A5" />
  <meta name="referrer" content="no-referrer-when-downgrade" />
  <link rel="icon" href="/img/a.jpg" />
  <link rel="stylesheet" href="https://at.alicdn.com/t/font_3077305_pt8umhrn4k9.css" />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" type="application/rss+xml" title="夏天夏" href={new URL('/rss.xml', Astro.site).href} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content={ogType} />
  <meta property="og:image" content={new URL('/img/a.jpg', Astro.site).href} />
  <meta property="og:locale" content="zh_CN" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL('/img/a.jpg', Astro.site).href} />
  {pageClass.includes('home-page') && (
    <link rel="preload" as="image" href="/img/bg.jpg" />
  )}
  <title>{fullTitle}</title>
</head>
<body class={pageClass}>
  <a href="#main-content" class="skip-to-content">跳到主要内容</a>
  <ReadingProgress />
  <header>
    <Navbar />
  </header>
  <main id="main-content">
    <slot />
  </main>
  <Footer />
  <BackToTop />
  <script src="../scripts/love-me.js"></script>
  <script src="../scripts/time-greeting.js"></script>
  <script src="../scripts/typing-animation.js"></script>
</body>
</html>

<style is:global>
  .skip-to-content {
    position: absolute;
    top: -100%;
    left: 0;
    padding: 0.5rem 1rem;
    background: var(--accent-color);
    color: #fff;
    z-index: 99999;
    text-decoration: none;
  }
  .skip-to-content:focus {
    top: 0;
  }
</style>
