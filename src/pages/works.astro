---
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkCard from '../components/WorkCard.astro';
import { WORKS } from '../utils/works-data';
---

<BaseLayout title="我的作品" description="夏天夏的作品集：独立开发的产品、工具与开源组件">
  <div class="works-page">
    <header class="works-hero">
      <p class="works-eyebrow">Works · {WORKS.length}</p>
      <h1>我的作品</h1>
      <p class="works-lead">独立开发的产品、工具与开源组件。点进去看详细介绍，或直接访问线上版本。</p>
    </header>

    <ul class="works-grid">
      {WORKS.map((work, i) => (
        <li><WorkCard work={work} index={i} /></li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  .works-page {
    max-width: var(--home-page-width);
    margin: 0 auto;
    padding: calc(var(--navbar-height) + 2.5rem) 1.5rem 4rem;
  }

  .works-hero {
    margin-bottom: 2.5rem;
    padding-left: 0.25rem;
  }

  .works-eyebrow {
    margin: 0 0 0.5rem;
    font-size: var(--font-size-xs);
    font-family: var(--font-family-mono);
    color: var(--text-lighten-color);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .works-hero h1 {
    margin: 0 0 0.75rem;
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    color: var(--text-color);
    line-height: var(--line-height-tight);
    font-weight: 700;
  }

  .works-lead {
    margin: 0;
    color: var(--text-lighten-color);
    font-size: var(--font-size-base);
    max-width: 48ch;
    line-height: var(--line-height-base);
  }

  .works-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }

  .works-grid > li {
    display: flex;
  }

  @media (max-width: 480px) {
    .works-page {
      padding-left: 1rem;
      padding-right: 1rem;
    }
  }
</style>
