---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeBanner from '../components/HomeBanner.astro';
import Sidebar from '../components/Sidebar.astro';
import SiteInfo from '../components/SiteInfo.astro';
import RecentArticles from '../components/RecentArticles.astro';
import PostList from '../components/PostList.astro';
import Pagination from '../components/Pagination.astro';
import { getAllArticles } from '../utils/content';
import { PAGE_SIZE } from '../utils/site-config';

const allArticles = await getAllArticles();

const currentPage = 1;
const totalPages = Math.ceil(allArticles.length / PAGE_SIZE);
const articles = allArticles.slice(0, PAGE_SIZE);
---

<BaseLayout pageClass="home-page">
  <HomeBanner />

  <div class="home-content">
    <div class="home-wrapper">
      <div class="home-main">
        <PostList articles={articles} />
        <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl="/page/" />
      </div>

      <Sidebar>
        <SiteInfo />
        <RecentArticles />
      </Sidebar>
    </div>
  </div>
</BaseLayout>

<style>
  .home-content {
    max-width: var(--home-page-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .home-wrapper {
    display: flex;
    gap: 2rem;
  }

  .home-main {
    flex: 1;
    min-width: 0;
  }

  @media (max-width: 1024px) {
    .home-wrapper {
      flex-direction: column;
    }
  }
</style>
